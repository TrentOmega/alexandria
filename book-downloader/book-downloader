#!/bin/bash
# Book Downloader Skill
# Default backend: Playwright + real Chrome automation.

set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OUTPUT_DIR="${2:-${HOME}/Downloads}"
QUERY="${1:-}"

mkdir -p "$OUTPUT_DIR"

source "$SCRIPT_DIR/scripts/common.sh"
aa_load_env "$SCRIPT_DIR"

if [ -z "$QUERY" ]; then
    echo "Usage: $0 \"book query\" [output_dir]"
    exit 1
fi

BACKEND="${ANNAS_DOWNLOADER_BACKEND:-playwright}"
PYTHON_BIN="${SCRIPT_DIR}/.venv/bin/python"

if [ ! -x "$PYTHON_BIN" ]; then
    PYTHON_BIN="python3"
fi

case "$BACKEND" in
    playwright)
        exec "$PYTHON_BIN" "$SCRIPT_DIR/scripts/anna_browser.py" "$QUERY" "$OUTPUT_DIR"
        ;;
    curl)
        aa_validate_setup || exit 1
        exec "$SCRIPT_DIR/scripts/legacy_curl_downloader.sh" "$QUERY" "$OUTPUT_DIR"
        ;;
    *)
        echo "Unsupported ANNAS_DOWNLOADER_BACKEND: $BACKEND"
        echo "Supported backends: playwright, curl"
        exit 1
        ;;
esac
